# Frontend Supabase config
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_CITIZEN_PHOTO_BUCKET="citizen-photos"

# R pipeline / PostgreSQL import
# Use the Supabase pooled or direct Postgres connection string.
# The R pipeline now loads this automatically from .env.local, .env,
# pipeline/.env.local, or pipeline/.env.
DATABASE_URL="postgresql://postgres.your-project:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require"

# Optional database-backed steps. Leave these unset or "0" while just staging
# map tiles for manual upload.
SUPABASE_OBSERVATIONS_ENABLED="0"
POSTGRES_IMPORT_ENABLED="0"

# Optional strict mode. Use "1" only when the run must fail if the database
# export/import cannot complete.
SUPABASE_OBSERVATIONS_REQUIRED="0"
POSTGRES_IMPORT_REQUIRED="0"
